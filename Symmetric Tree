#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution(object):
    def isSymmetric(self, root):
        """
        :type root: Optional[TreeNode]
        :rtype: bool
        """
        def trav(root,l):
            if root==None:
                return
            if (root.left==None and root.right!=None):
                l.append(".")
            if (root.left!=None and root.right==None):
                l.append(",")
            trav(root.left,l)
            l.append(root.val)
            trav(root.right,l)
        def trav2(root,l):
            if root==None:
                return
            if (root.left!=None and root.right==None):
                l.append(".")
            if (root.left==None and root.right!=None):
                l.append(",")
            trav2(root.right,l)
            l.append(root.val)
            trav2(root.left,l)
        a=[]
        b=[]
        trav(root,a)
        trav2(root,b)
        print(a,b)
        if len(a)==1:
            return True
        if len(a)==2:
            return False
        if a==b:
            return True
        return False
