class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        n=0
        prefix=''
        first=strs[n]
        if (len(strs)==0):
            return ''
        elif (len(strs)==1):
            return strs[0]
        else:
            for i in first:
                matched=False
                for k in range (1,len(strs)):
                    if n<len(strs[k]):
                        if i==strs[k][n]:
                            matched=True
                        else:
                            matched=False
                            break
                    else:
                        matched=False
                        break
                if(matched):
                    prefix+=i
                else:
                    break
                n+=1
        return prefix
