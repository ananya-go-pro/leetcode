class Solution:
    def isPowerOfThree(self, n: int) -> bool:
        if (n==1):
            return True
        if (n<=0) or (n%2==0) or (n%3!=0):
            return False
        def tres(x):
            if x%3!=0:
                return False
            elif x>3:
                return tres(x/3)
            return True
        return tres(n)
