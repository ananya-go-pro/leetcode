class Solution:
    def isHappy(self, n: int) -> bool:
        if n==1:
            return True
        elif n**2<10:
            return False
        else: 
            a=str(n)
            while int(a)>=7:
                c=0    
                for i in a:
                    c+=(int(i)**2)
                a=str(c)
            if a=="1":
                return True
            elif int(a)<10:
                return False
