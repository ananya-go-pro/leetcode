class Solution(object):
    def countMajoritySubarrays(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: int
        """
        if target not in nums:
            return 0
        if len(nums)==1:
            return 1
        count=0
        for i in range(0,len(nums)):
            c=0
            for j in range(i,len(nums)):
                if nums[j]==target:
                    c+=1
                l=j-i+1
                if 2*c>l:
                    count+=1
        return count
